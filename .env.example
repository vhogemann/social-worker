SW_API_IMAGE=ghcr.io/vhogemann/social-worker-api:latest
SW_WEB_IMAGE=ghcr.io/vhogemann/social-worker-web:latest

LLM__BaseUrl=https://openrouter.ai/api/v1
LLM__ApiKey=or-...
LLM__Model=anthropic/claude-3.5-sonnet
# Set only for deterministic e2e runs. Leave empty for normal local usage.
DEMO_LLM_PROFILE=

Search__Provider=SearXng
Search__BraveApiKey=

ConnectionStrings__Default=Host=localhost;Database=socialworker;Username=postgres;Password=postgres

Postgres__Password=postgres

# Auth Configuration
Auth__JwtSecret=secret_key_must_be_at_least_32_characters_long_for_security_reasons
Auth__AdminPassword=changeme
Auth__AccessTokenLifetimeMinutes=60
Auth__RefreshTokenLifetimeDays=7
Auth__DbEncryptionKey=6Hu0Ff4LtNcJDESsBHL40zKqhfOoAVKURp+8jAwZQLw=

# Transcriber / Whisper service
TRANSCRIBER__WhisperModel=base
TRANSCRIBER__SummaryEngine=disabled
TRANSCRIBER__SummaryUrl=
TRANSCRIBER__SummaryModel=
TRANSCRIBER__SummaryApiKey=
TRANSCRIBER__SummaryMaxChars=12000
TRANSCRIBER__TimeoutSeconds=1800
